# Trace Backend Configuration
# Copy this file to .env and fill in actual values for your deployment

# === SECURITY ===
# REQUIRED: Change this to a strong random string in production
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
TRACE_SECRET_KEY=dev-insecure-secret-change-me-in-production

# === DATABASE ===
# Development (SQLite)
# TRACE_DB_URL=sqlite:///./trace.db

# Production (PostgreSQL)
# TRACE_DB_URL=postgresql://user:password@localhost:5432/trace_db

# Railway PostgreSQL (auto-filled when you connect the database)
# TRACE_DB_URL=postgresql://user:password@container.railway.app:5432/railway

# === JWT ===
# Token time-to-live in minutes (default: 12 hours)
TRACE_TOKEN_TTL_MIN=720

# === CORS ===
# Frontend origin for CORS (must match deployed frontend URL)
TRACE_FRONTEND_ORIGIN=http://localhost:5173

# === DEPLOYMENT ===
# Set to "production" to disable debug mode
ENVIRONMENT=development
